rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can read/write their own state document and all subcollections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /history/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
