{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/overlay.html",
        "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
      }
    ],
    "rewrites": [
      { "source": "/overlay.html", "destination": "/404.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
